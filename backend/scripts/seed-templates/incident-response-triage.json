      "name": "virustotal_api_key",
      "type": "string",
      "description": "VirusTotal API key for threat intelligence lookups"
    },
    {
      "name": "abuseipdb_api_key",
      "type": "string",
      "description": "AbuseIPDB API key for IP reputation checks"
    },
    {
      "name": "slack_webhook_url",
      "type": "string",
