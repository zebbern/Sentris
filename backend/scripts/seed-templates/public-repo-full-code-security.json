      {
        "id": "dedupe_findings",
        "type": "core.logic.script",
        "position": { "x": 1100, "y": 400 },
        "data": {
          "label": "Dedupe Cross-Scanner Findings",
          "config": {
            "params": {
              "variables": [
                { "name": "repositoryUrl", "type": "string" },
                { "name": "ref", "type": "string" },
                { "name": "authorizationNotes", "type": "string" },
                { "name": "secrets", "type": "list-json" },
                { "name": "secretCount", "type": "number" },
                { "name": "verifiedCount", "type": "number" },
                { "name": "hasVerifiedSecrets", "type": "boolean" },
                { "name": "semgrepFindings", "type": "list-json" },
                { "name": "semgrepCount", "type": "number" },
                { "name": "npmFindings", "type": "list-json" },
                { "name": "pypiFindings", "type": "list-json" },
                { "name": "goFindings", "type": "list-json" },
                { "name": "mavenFindings", "type": "list-json" },
                { "name": "packagistFindings", "type": "list-json" },
                { "name": "npmSummary", "type": "json" },
                { "name": "pypiSummary", "type": "json" },
                { "name": "goSummary", "type": "json" },
                { "name": "mavenSummary", "type": "json" },
                { "name": "packagistSummary", "type": "json" }
              ],
              "returns": [{ "name": "report", "type": "json" }],
              "code": "export function script(input) {\n  const severityRank = { critical: 5, high: 4, error: 4, medium: 3, warning: 3, low: 2, info: 1, unknown: 0 };\n  const list = (value) => Array.isArray(value) ? value : [];\n  const normalizeSeverity = (value) => String(value || 'unknown').toLowerCase();\n  const rank = (value) => severityRank[normalizeSeverity(value)] || 0;\n  const repositoryUrl = typeof input.repositoryUrl === 'string' ? input.repositoryUrl.trim() : '';\n  const ref = typeof input.ref === 'string' && input.ref.trim().length > 0 ? input.ref.trim() : null;\n  const authorizationNotes = typeof input.authorizationNotes === 'string' && input.authorizationNotes.trim().length > 0 ? input.authorizationNotes.trim() : null;\n  function firstText(...values) {\n    for (const value of values) {\n      if (typeof value === 'string' && value.trim().length > 0) return value.trim();\n    }\n    return null;\n  }\n  function gitData(secret) {\n    const data = secret?.SourceMetadata?.Data || {};\n    return data.Git || data.Github || data.Gitlab || data.Filesystem || {};\n  }\n  function redactedValue(secret) {\n    return firstText(secret?.Redacted, secret?.StructuredData?.redacted, secret?.StructuredData?.Redacted) || '[redacted]';\n  }\n  const secretFindings = list(input.secrets).map((secret) => {\n    const source = gitData(secret);\n    const detector = firstText(secret?.DetectorName, secret?.DetectorType, 'Unknown secret') || 'Unknown secret';\n    const file = firstText(source.file, source.path, secret?.SourceMetadata?.Data?.Filesystem?.file);\n    const location = file || repositoryUrl;\n    const severity = secret?.Verified === true ? 'high' : 'medium';\n    const ruleId = firstText(secret?.DetectorType, secret?.DetectorName);\n    return {\n      source: 'trufflehog',\n      severity: normalizeSeverity(severity),\n      title: detector + (secret?.Verified === true ? ' (verified)' : ''),\n      ruleId,\n      location,\n      dedupeKey: 'trufflehog|' + (ruleId || detector) + '|' + location,\n      verified: secret?.Verified === true,\n      redacted: redactedValue(secret),\n      raw: { detector, file, redacted: redactedValue(secret), verified: secret?.Verified === true }\n    };\n  });\n  const semgrepFindings = list(input.semgrepFindings).map((item) => {\n    const location = item.path ? item.path + ':' + (item.startLine || 0) : null;\n    const ruleId = item.checkId || null;\n    return {\n      source: 'semgrep',\n      severity: normalizeSeverity(item.severity),\n      title: item.message || item.checkId || 'Semgrep finding',\n      ruleId,\n      location,\n      dedupeKey: 'semgrep|' + (ruleId || item.message || '') + '|' + (location || ''),\n      raw: item\n    };\n  });\n  const osvEcosystems = ['npm', 'pypi', 'go', 'maven', 'packagist'];\n  const osvFindings = osvEcosystems.flatMap((eco) => list(input[eco + 'Findings']).map((finding) => {\n    const location = finding.packageSpec || finding.packageName || null;\n    const ruleId = finding.id || null;\n    return {\n      source: 'osv-' + eco,\n      severity: normalizeSeverity(finding.severity),\n      title: String(finding.summary || finding.id || 'Dependency advisory').slice(0, 200),\n      ruleId,\n      location,\n      dedupeKey: 'osv|' + (ruleId || '') + '|' + (location || ''),\n      raw: finding\n    };\n  }));\n  const dedupeMap = new Map();\n  for (const finding of [...secretFindings, ...semgrepFindings, ...osvFindings]) {\n    if (!dedupeMap.has(finding.dedupeKey)) dedupeMap.set(finding.dedupeKey, finding);\n  }\n  const findings = Array.from(dedupeMap.values()).sort((a, b) => rank(b.severity) - rank(a.severity) || String(a.title).localeCompare(String(b.title)));\n  const countsBySource = findings.reduce((acc, item) => { acc[item.source] = (acc[item.source] || 0) + 1; return acc; }, {});\n  const countsBySeverity = findings.reduce((acc, item) => { acc[item.severity] = (acc[item.severity] || 0) + 1; return acc; }, {});\n  const secretCount = Number.isFinite(Number(input.secretCount)) ? Number(input.secretCount) : list(input.secrets).length;\n  const verifiedCount = Number.isFinite(Number(input.verifiedCount)) ? Number(input.verifiedCount) : secretFindings.filter((item) => item.verified).length;\n  return {\n    report: {\n      summary: {\n        repositoryUrl,\n        ref,\n        findings: findings.length,\n        secretCount,\n        verifiedSecretCount: verifiedCount,\n        semgrepFindings: Number(input.semgrepCount || list(input.semgrepFindings).length),\n        dependencyFindings: osvFindings.length,\n        highestSeverity: findings[0]?.severity || null,\n        countsBySource,\n        countsBySeverity\n      },\n      authorizationNotes,\n      scannerSummaries: {\n        trufflehog: {\n          secretCount,\n          verifiedCount,\n          hasVerifiedSecrets: input.hasVerifiedSecrets === true || verifiedCount > 0\n        },\n        semgrep: { findingCount: Number(input.semgrepCount || list(input.semgrepFindings).length) },\n        osv: {\n          npm: input.npmSummary && typeof input.npmSummary === 'object' ? input.npmSummary : {},\n          pypi: input.pypiSummary && typeof input.pypiSummary === 'object' ? input.pypiSummary : {},\n          go: input.goSummary && typeof input.goSummary === 'object' ? input.goSummary : {},\n          maven: input.mavenSummary && typeof input.mavenSummary === 'object' ? input.mavenSummary : {},\n          packagist: input.packagistSummary && typeof input.packagistSummary === 'object' ? input.packagistSummary : {}\n        }\n      },\n      priorityFindings: findings.slice(0, 100),\n      nextSteps: [\n        'Rotate any verified exposed credentials immediately',\n        'Prioritize critical and high Semgrep and dependency findings for manual validation',\n        'Confirm all findings are in authorized program scope before reporting',\n        'Use redacted secret evidence only in submissions'\n      ]\n    }\n  };\n}"
            },
            "inputOverrides": {}
          }
        }
