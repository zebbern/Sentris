      {
        "id": "assemble_code_risk_report",
        "type": "core.logic.script",
        "position": {
          "x": 1120,
          "y": 360
        },
        "data": {
          "label": "Assemble Code Risk Report",
          "config": {
            "params": {
              "variables": [
                {
                  "name": "repositoryUrl",
                  "type": "string"
                },
                {
                  "name": "authorizationNotes",
                  "type": "string"
                },
                {
                  "name": "fileSummary",
                  "type": "json"
                },
                {
                  "name": "files",
                  "type": "list-json"
                },
                {
                  "name": "skippedFiles",
                  "type": "list-json"
                },
                {
                  "name": "semgrepFindings",
                  "type": "list-json"
                },
                {
                  "name": "semgrepCount",
                  "type": "number"
                },
                {
                  "name": "terraformViolations",
                  "type": "list-json"
                },
                {
                  "name": "kubernetesViolations",
                  "type": "list-json"
                },
                {
                  "name": "dockerfileViolations",
                  "type": "list-json"
                },
                {
                  "name": "cloudformationViolations",
                  "type": "list-json"
                },
                {
                  "name": "trivyVulnerabilities",
                  "type": "list-json"
                },
                {
                  "name": "trivyCount",
                  "type": "number"
                }
              ],
              "returns": [
                {
                  "name": "report",
                  "type": "json"
                }
              ],
              "code": "export function script(input) {\n  const severityRank = { critical: 5, high: 4, error: 4, medium: 3, warning: 3, low: 2, info: 1, unknown: 0 };\n  const list = (value) => Array.isArray(value) ? value : [];\n  const normalizeSeverity = (value) => String(value || 'unknown').toLowerCase();\n  const rank = (value) => severityRank[normalizeSeverity(value)] || 0;\n  const fileSummary = input.fileSummary && typeof input.fileSummary === 'object' ? input.fileSummary : {};\n  const semgrep = list(input.semgrepFindings).map((item) => ({\n    source: 'semgrep',\n    severity: normalizeSeverity(item.severity),\n    title: item.message || item.checkId || 'Semgrep finding',\n    ruleId: item.checkId || null,\n    location: item.path ? item.path + ':' + (item.startLine || 0) : null,\n    cwe: Array.isArray(item.cwe) ? item.cwe : [],\n    raw: item\n  }));\n  const checkovSource = (items, framework) => list(items).map((item) => ({\n    source: 'checkov',\n    framework,\n    severity: normalizeSeverity(item.severity || 'medium'),\n    title: item.description || item.checkId || 'Checkov violation',\n    ruleId: item.checkId || null,\n    location: item.filePath || item.resource || null,\n    guideline: item.guideline || null,\n    raw: item\n  }));\n  const trivy = list(input.trivyVulnerabilities).map((item) => ({\n    source: 'trivy',\n    severity: normalizeSeverity(item.severity),\n    title: item.title || item.vulnerabilityId || 'Trivy vulnerability',\n    vulnerabilityId: item.vulnerabilityId || null,\n    packageName: item.pkgName || null,\n    installedVersion: item.installedVersion || null,\n    fixedVersion: item.fixedVersion || null,\n    primaryUrl: item.primaryUrl || null,\n    raw: item\n  }));\n  const findings = [\n    ...semgrep,\n    ...checkovSource(input.terraformViolations, 'terraform'),\n    ...checkovSource(input.kubernetesViolations, 'kubernetes'),\n    ...checkovSource(input.dockerfileViolations, 'dockerfile'),\n    ...checkovSource(input.cloudformationViolations, 'cloudformation'),\n    ...trivy\n  ].sort((a, b) => rank(b.severity) - rank(a.severity) || String(a.title).localeCompare(String(b.title)));\n  const countsBySource = findings.reduce((acc, item) => { acc[item.source] = (acc[item.source] || 0) + 1; return acc; }, {});\n  const countsBySeverity = findings.reduce((acc, item) => { acc[item.severity] = (acc[item.severity] || 0) + 1; return acc; }, {});\n  return {\n    report: {\n      summary: {\n        repository: input.repositoryUrl || fileSummary.repository || null,\n        ref: fileSummary.ref || null,\n        selectedFiles: Number(fileSummary.selectedFiles || 0),\n        skippedFiles: Array.isArray(input.skippedFiles) ? input.skippedFiles.length : Number(fileSummary.skippedFiles || 0),\n        findings: findings.length,\n        semgrepFindings: Number(input.semgrepCount || semgrep.length),\n        checkovViolations: checkovSource(input.terraformViolations, 'terraform').length + checkovSource(input.kubernetesViolations, 'kubernetes').length + checkovSource(input.dockerfileViolations, 'dockerfile').length + checkovSource(input.cloudformationViolations, 'cloudformation').length,\n        trivyVulnerabilities: Number(input.trivyCount || trivy.length),\n        highestSeverity: findings[0]?.severity || null,\n        countsBySource,\n        countsBySeverity\n      },\n      authorizationNotes: input.authorizationNotes || null,\n      extraction: {\n        summary: fileSummary,\n        files: list(input.files).slice(0, 120),\n        skippedFiles: list(input.skippedFiles).slice(0, 120)\n      },\n      priorityFindings: findings.slice(0, 100),\n      nextSteps: [\n        'Confirm findings manually against the exact repository revision and program scope',\n        'Prioritize high-severity Trivy vulnerabilities with fixed versions and reachable code paths',\n        'Review Semgrep findings for exploitability before filing a report',\n        'Validate IaC violations against deployment context before reporting impact'\n      ]\n    }\n  };\n}"
            },
            "inputOverrides": {}
          }
        }
