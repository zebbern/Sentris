    "tags": ["bug-bounty", "github", "sast", "iac", "semgrep", "checkov", "trivy"],
    "author": "sentris-team",
    "version": "1.0.0"
  },
  "manifest": {
    "name": "Public Repo Code & IaC Risk Triage",
    "description": "Review authorized public GitHub repositories for source-code, IaC, and dependency/container risk signals with bounded extraction and scanner triage.",
    "version": "1.0.0",
    "author": "sentris-team",
    "category": "bug-bounty",
    "tags": ["bug-bounty", "github", "sast", "iac", "semgrep", "checkov", "trivy"],
    "entryPoint": "trigger_1",
    "nodeCount": 10,
    "edgeCount": 23
  },
  "graph": {
    "name": "Public Repo Code & IaC Risk Triage",
    "description": "Bounded public repository source and IaC risk workflow for authorized bug bounty targets.",
